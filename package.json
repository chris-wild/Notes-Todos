{
  "name": "notes-todos-app",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:3001",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "semgrep": "semgrep --config=p/javascript --config=p/react --config=p/secrets --exclude='backend/db.js' --error .",
    "semgrep:fix": "semgrep --config=p/javascript --config=p/react --config=p/secrets --exclude='backend/db.js' --dry-run --fix",
    "owasp:baseline": "bash scripts/owasp-scan.sh",
    "owasp:full": "bash scripts/owasp-scan.sh --full"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
