# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/notes_todos

# Optional (recommended for production)
# JWT_SECRET=change-me

# Optional: set to true/1/require for AWS RDS SSL connections
# PGSSL=true

# Optional (recommended on AWS): store recipe PDFs in S3
# If S3_BUCKET is set, recipe PDFs are stored in S3 and streamed back via /api/recipes/:id/pdf
# AWS_REGION=eu-west-2
# S3_BUCKET=your-bucket-name

# Optional: OCR / ingredient extraction (server-side)
# OPENAI_API_KEY=...
# OCR_MODEL=gpt-4o-mini
